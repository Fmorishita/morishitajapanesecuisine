{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/create-checkout-session",
      "dest": "backend/server.js"
    },
    {
      "src": "/stripe-webhook",
      "dest": "backend/server.js"
    },
    {
      "src": "/stripe-webhook-client",
      "dest": "backend/server.js"
    },
    {
      "src": "/disponibilidad",
      "dest": "backend/server.js"
    },
    {
      "src": "/disponibilidad\\?(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/health",
      "dest": "backend/server.js"
    },
    {
      "src": "/admin",
      "dest": "/admin/index.html"
    },
    {
      "src": "/admin/",
      "dest": "/admin/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
