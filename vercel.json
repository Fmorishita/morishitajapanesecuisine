{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.png",
      "use": "@vercel/static"
    },
    {
      "src": "favicon.ico",
      "use": "@vercel/static"
    },
    {
      "src": "img/**/*.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/create-checkout-session",
      "dest": "backend/server.js"
    },
    {
      "src": "/stripe-webhook",
      "dest": "backend/server.js"
    },
    {
      "src": "/stripe-webhook-client",
      "dest": "backend/server.js"
    },
    {
      "src": "/disponibilidad",
      "dest": "backend/server.js"
    },
    {
      "src": "/disponibilidad\\?(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/health",
      "dest": "backend/server.js"
    },
    {
      "src": "/img/(.*)",
      "dest": "/img/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/favicon.png",
      "dest": "/favicon.png",
      "headers": { "cache-control": "public, max-age=86400" }
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico",
      "headers": { "cache-control": "public, max-age=86400" }
    },
    {
      "src": "/admin",
      "dest": "/admin/index.html"
    },
    {
      "src": "/admin/",
      "dest": "/admin/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
